---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Not Found" description="The requested page could not be found.">
  <section class="empty-state" data-reveal>
    <span class="eyebrow">404</span>
    <h1>That page is not available.</h1>
    <p>The link may be outdated, or the page may not be public yet. You can return to the homepage and continue from there.</p>
    <a class="button-link primary" href="/">Back to home</a>
  </section>
</BaseLayout>
